<section class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-black/8" data-section-type="lifestyle-grid">
  {%- for n in (1..3) -%}
    {%- assign image_key = 'image' | append: n -%}
    {%- assign image = section.settings[image_key] -%}
    <div class="relative aspect-square overflow-hidden img-zoom-parent bg-v-cream">
      {%- if image != blank -%}
        {{
          image
          | image_url: width: 800
          | image_tag:
            class: 'img-zoom absolute inset-0 w-full h-full object-cover',
            widths: '300, 450, 600, 800',
            sizes: '(min-width: 1024px) 25vw, 50vw',
            loading: 'lazy',
            alt: image.alt
        }}
      {%- else -%}
        {{ 'lifestyle-' | append: n | placeholder_svg_tag: 'absolute inset-0 w-full h-full object-cover bg-v-rose-light' }}
      {%- endif -%}
    </div>
  {%- endfor -%}

  <a
    href="{{ section.settings.instagram_url | default: '#' }}"
    target="_blank"
    rel="noopener"
    class="relative aspect-square overflow-hidden bg-black flex items-center justify-center text-center group"
  >
    <div class="px-6 transition-transform duration-500 group-hover:scale-[0.97]">
      <svg class="w-7 h-7 mx-auto text-white mb-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M16 12a4 4 0 11-8 0 4 4 0 018 0zM7 3h10a4 4 0 014 4v10a4 4 0 01-4 4H7a4 4 0 01-4-4V7a4 4 0 014-4zm10 5h.01"/>
      </svg>
      <p class="font-serif text-white text-2xl font-light italic mb-2">{{ section.settings.instagram_handle }}</p>
      <p class="text-white/40 text-[8px] tracking-[.4em] uppercase font-light">
        {{ 'sections.lifestyle.follow' | t }}
      </p>
    </div>
  </a>
</section>

{% schema %}
{
  "name": "t:sections.lifestyle_grid.name",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image1", "label": "t:labels.image", "info": "1" },
    { "type": "image_picker", "id": "image2", "label": "t:labels.image", "info": "2" },
    { "type": "image_picker", "id": "image3", "label": "t:labels.image", "info": "3" },
    {
      "type": "text",
      "id": "instagram_handle",
      "label": "t:labels.instagram_handle",
      "default": "@valentinaskincare"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "t:labels.instagram_url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.lifestyle_grid.name"
    }
  ]
}
{% endschema %}
