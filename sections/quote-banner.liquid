<section
  class="relative h-[70vh] min-h-[480px] flex items-center justify-center overflow-hidden"
  data-section-type="quote-banner"
>
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 2400
      | image_tag:
        class: 'absolute inset-0 w-full h-full object-cover',
        widths: '600, 900, 1200, 1600, 2000, 2400',
        sizes: '100vw',
        loading: 'lazy',
        alt: section.settings.image.alt
    }}
  {%- else -%}
    <div class="absolute inset-0 bg-gradient-to-br from-v-rose-light to-v-rose"></div>
  {%- endif -%}

  <div class="absolute inset-0 bg-black/30"></div>

  <div class="relative z-10 text-center text-white px-6 max-w-3xl">
    {%- if section.settings.quote != blank -%}
      <p
        class="reveal font-serif italic font-light leading-[1.32] mb-7"
        style="font-size: clamp(1.6rem, 3.6vw, 2.6rem);"
      >
        &ldquo;{{ section.settings.quote }}&rdquo;
      </p>
    {%- endif -%}

    {%- if section.settings.author != blank -%}
      <p class="reveal d1 text-white/60 text-[9px] tracking-[.45em] uppercase font-light">
        — {{ section.settings.author }}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.quote_banner.name",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.background_image"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "t:labels.quote",
      "default": "True beauty is not painted on the surface. It rises from beneath, slowly, like dawn."
    },
    {
      "type": "text",
      "id": "author",
      "label": "t:labels.author",
      "default": "Valentina, Founder"
    }
  ],
  "presets": [
    {
      "name": "t:sections.quote_banner.name"
    }
  ]
}
{% endschema %}
