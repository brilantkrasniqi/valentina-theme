{%- assign crumb = 'sections.customers_login.breadcrumb' | t -%}
{% render 'breadcrumbs', current_label: crumb %}

<section class="pb-24 px-6 md:px-10 bg-v-cream" data-section-type="customers-login">
  <div class="max-w-md mx-auto pt-6">
    <h1 class="font-serif text-3xl font-light text-black mb-8 text-center">{{ 'customers.login.title' | t }}</h1>

    <div class="border border-black/10 bg-white/50 p-8 md:p-10">
      {% form 'customer_login', novalidate: 'novalidate' %}
        {{ form.errors | default_errors }}

        <div class="space-y-5">
          <div>
            <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="CustomerEmail">{{ 'customers.login.email' | t }}</label>
            <input
              type="email"
              name="customer[email]"
              id="CustomerEmail"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              value="{{ form.email }}"
              class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
              placeholder="{{ 'customers.login.email' | t }}"
            >
          </div>

          {%- if form.password_needed -%}
            <div>
              <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="CustomerPassword">{{ 'customers.login.password' | t }}</label>
              <input
                type="password"
                name="customer[password]"
                id="CustomerPassword"
                autocomplete="current-password"
                class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
                placeholder="{{ 'customers.login.password' | t }}"
              >
            </div>
          {%- endif -%}

          <button type="submit" class="w-full text-white text-[10px] tracking-[.38em] uppercase font-light bg-v-rose py-[14px] hover:bg-black transition-all duration-500 min-h-[48px]">
            {{ 'customers.login.sign_in' | t }}
          </button>
        </div>
      {% endform %}

      <div class="mt-8 pt-8 border-t border-black/10 space-y-4 text-center text-[10px] tracking-[.28em] uppercase font-light">
        <p>
          <a href="{{ routes.account_register_url }}" class="text-black/50 hover:text-v-rose transition-colors">{{ 'customers.login.create_account' | t }}</a>
        </p>
        {%- if shop.checkout.guest_login -%}
          <p class="text-black/35">{{ 'customers.login.or' | t }}</p>
          {% form 'guest_login' %}
            <button type="submit" class="w-full text-black border border-black/20 py-3 hover:bg-black hover:text-white transition-all duration-500">
              {{ 'customers.login.guest_continue' | t }}
            </button>
          {% endform %}
        {%- endif -%}
        <p>
          <a href="{{ routes.account_recover_url }}" class="text-black/50 hover:text-v-rose transition-colors">{{ 'customers.login.forgot_password' | t }}</a>
        </p>
        <p>
          <a href="{{ routes.root_url }}" class="text-black/35 hover:text-v-rose transition-colors">{{ 'customers.login.cancel' | t }}</a>
        </p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.customers_login.name",
  "tag": "section",
  "class": "section-customers-login",
  "settings": [],
  "enabled_on": {
    "templates": ["customers/login"]
  }
}
{% endschema %}
