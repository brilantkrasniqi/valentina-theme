<header
  id="SiteHeader"
  data-site-header
  class="fixed top-0 inset-x-0 z-50 py-5 px-6 md:px-10 transition-[background-color,border-color,backdrop-filter] duration-500"
>
  <div class="max-w-screen-2xl mx-auto flex items-center justify-between relative">

    {%- # Left navigation -%}
    <nav class="hidden md:flex items-center gap-9" aria-label="{{ 'general.accessibility.primary_nav' | t }}">
      {%- for link in section.settings.menu_left.links -%}
        <a
          href="{{ link.url }}"
          class="nav-link ul-hover text-white text-[10px] tracking-[.38em] uppercase font-light hover:text-v-rose transition-colors duration-300"
        >{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    {%- # Centered logo -%}
    <a
      href="{{ routes.root_url }}"
      class="absolute left-1/2 -translate-x-1/2 text-center select-none"
      aria-label="{{ shop.name }}"
    >
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 240
          | image_tag:
            class: 'nav-logo h-9 md:h-10 w-auto mx-auto',
            widths: '120, 240, 360',
            alt: shop.name,
            loading: 'eager'
        }}
      {%- else -%}
        <p class="nav-logo font-serif text-white text-[1.7rem] font-light tracking-[.28em] uppercase leading-none">
          {{ shop.name }}
        </p>
        {%- if section.settings.tagline != blank -%}
          <p class="nav-sub text-white text-[7.5px] tracking-[.5em] uppercase font-light opacity-55 mt-[3px]">
            {{ section.settings.tagline }}
          </p>
        {%- endif -%}
      {%- endif -%}
    </a>

    {%- # Right navigation + icons -%}
    <nav class="hidden md:flex items-center gap-9" aria-label="{{ 'general.accessibility.secondary_nav' | t }}">
      {%- for link in section.settings.menu_right.links -%}
        <a
          href="{{ link.url }}"
          class="nav-link ul-hover text-white text-[10px] tracking-[.38em] uppercase font-light hover:text-v-rose transition-colors duration-300"
        >{{ link.title }}</a>
      {%- endfor -%}

      {%- if section.settings.show_localization -%}
        <details class="relative">
          <summary class="list-none cursor-pointer nav-link text-white text-[10px] tracking-[.38em] uppercase font-light hover:text-v-rose transition-colors duration-300">
            {{ localization.language.endonym_name | default: localization.language.iso_code | upcase }}
            {%- if localization.country -%}
              &nbsp;·&nbsp;{{ localization.country.currency.iso_code }}
            {%- endif -%}
          </summary>
          <div class="absolute right-0 top-full mt-3 bg-white text-black p-5 shadow-xl min-w-[12rem] space-y-4">
            {%- form 'localization', class: 'space-y-2' -%}
              <div>
                <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 mb-2">
                  {{ 'general.localization.language' | t }}
                </label>
                <select
                  name="locale_code"
                  class="w-full border border-black/10 px-2 py-1 text-sm font-light"
                  onchange="this.form.submit()"
                >
                  {%- for language in localization.available_languages -%}
                    <option
                      value="{{ language.iso_code }}"
                      lang="{{ language.iso_code }}"
                      {% if language.iso_code == localization.language.iso_code %}selected{% endif %}
                    >{{ language.endonym_name | capitalize }}</option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endform -%}

            {%- form 'localization', class: 'space-y-2' -%}
              <div>
                <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 mb-2">
                  {{ 'general.localization.country' | t }}
                </label>
                <select
                  name="country_code"
                  class="w-full border border-black/10 px-2 py-1 text-sm font-light"
                  onchange="this.form.submit()"
                >
                  {%- for country in localization.available_countries -%}
                    <option
                      value="{{ country.iso_code }}"
                      {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
                    >{{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})</option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endform -%}
          </div>
        </details>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" aria-label="{{ 'customers.login.title' | t }}" class="nav-link hover:text-v-rose transition-colors duration-300">
          <svg class="nav-icon w-[17px] h-[17px] stroke-white hover:stroke-v-rose transition-colors duration-300" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3" d="M16 14a4 4 0 10-8 0M12 11a3 3 0 100-6 3 3 0 000 6zm0 11c5.523 0 10-2.239 10-5s-4.477-5-10-5S2 14.239 2 17s4.477 5 10 5z"/>
          </svg>
        </a>
      {%- endif -%}

      <button
        type="button"
        data-cart-drawer-open
        aria-label="{{ 'cart.title' | t }}"
        class="nav-link relative"
      >
        <svg class="nav-icon w-[17px] h-[17px] stroke-white hover:stroke-v-rose transition-colors duration-300" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        <span
          data-cart-count
          class="absolute -top-2 -right-3 bg-v-rose text-white text-[9px] tracking-wider rounded-full min-w-[16px] h-[16px] px-1 inline-flex items-center justify-center {% if cart.item_count == 0 %}hidden{% endif %}"
        >{{ cart.item_count }}</span>
      </button>
    </nav>

    {%- # Mobile -%}
    <button
      type="button"
      class="md:hidden flex flex-col gap-[5px]"
      aria-label="{{ 'general.accessibility.menu' | t }}"
      data-mobile-menu-toggle
      aria-expanded="false"
      aria-controls="MobileMenu"
    >
      <span class="ham-bar"></span>
      <span class="ham-bar"></span>
      <span class="ham-bar !w-3 ml-auto"></span>
    </button>

    <div class="md:hidden absolute right-12 top-1/2 -translate-y-1/2">
      <button
        type="button"
        data-cart-drawer-open
        aria-label="{{ 'cart.title' | t }}"
        class="relative"
      >
        <svg class="nav-icon w-[17px] h-[17px] stroke-white" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
        <span
          data-cart-count
          class="absolute -top-2 -right-3 bg-v-rose text-white text-[9px] tracking-wider rounded-full min-w-[16px] h-[16px] px-1 inline-flex items-center justify-center {% if cart.item_count == 0 %}hidden{% endif %}"
        >{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

  {%- # Mobile menu drawer -%}
  <div
    id="MobileMenu"
    data-mobile-menu
    hidden
    class="md:hidden absolute inset-x-0 top-full bg-v-cream text-black border-t border-black/10 px-6 py-8 space-y-6"
  >
    <nav class="flex flex-col gap-5" aria-label="{{ 'general.accessibility.mobile_nav' | t }}">
      {%- for link in section.settings.menu_left.links -%}
        <a href="{{ link.url }}" class="text-[11px] tracking-[.38em] uppercase font-light">{{ link.title }}</a>
      {%- endfor -%}
      {%- for link in section.settings.menu_right.links -%}
        <a href="{{ link.url }}" class="text-[11px] tracking-[.38em] uppercase font-light">{{ link.title }}</a>
      {%- endfor -%}
    </nav>
  </div>
</header>

{%- # Spacer so content is not hidden under the fixed header on non-hero templates -%}
{%- if template.name != 'index' -%}
  <div aria-hidden="true" class="h-20"></div>
{%- endif -%}

{% stylesheet %}
  [data-site-header].is-scrolled,
  [data-site-header].is-solid {
    background: rgba(250, 248, 245, 0.96);
    border-bottom: 1px solid rgba(222, 170, 166, 0.18);
    backdrop-filter: blur(14px);
  }
  [data-site-header].is-scrolled .nav-link,
  [data-site-header].is-solid .nav-link,
  [data-site-header].is-scrolled .nav-logo,
  [data-site-header].is-solid .nav-logo {
    color: #1a1a1a;
  }
  [data-site-header].is-scrolled .nav-sub,
  [data-site-header].is-solid .nav-sub {
    color: #1a1a1a;
    opacity: 0.35;
  }
  [data-site-header].is-scrolled .nav-icon,
  [data-site-header].is-solid .nav-icon {
    stroke: #1a1a1a;
  }
  [data-site-header].is-scrolled .ham-bar,
  [data-site-header].is-solid .ham-bar {
    background: #1a1a1a;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var header = document.querySelector('[data-site-header]');
    if (!header) return;

    var isHomepage = document.body.getAttribute('data-template') === 'index' || document.querySelector('main [data-section-type="hero"]') !== null;

    function updateHeaderState() {
      var past = window.scrollY > 72;
      header.classList.toggle('is-scrolled', past);
    }

    if (!isHomepage) {
      header.classList.add('is-solid');
    } else {
      window.addEventListener('scroll', updateHeaderState, { passive: true });
      updateHeaderState();
    }

    var toggle = header.querySelector('[data-mobile-menu-toggle]');
    var menu = header.querySelector('[data-mobile-menu]');
    if (toggle && menu) {
      toggle.addEventListener('click', function () {
        var open = menu.hasAttribute('hidden') === false;
        if (open) {
          menu.setAttribute('hidden', '');
          toggle.setAttribute('aria-expanded', 'false');
        } else {
          menu.removeAttribute('hidden');
          toggle.setAttribute('aria-expanded', 'true');
          header.classList.add('is-solid');
        }
      });
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Luxury Skincare"
    },
    {
      "type": "link_list",
      "id": "menu_left",
      "label": "t:labels.menu_left"
    },
    {
      "type": "link_list",
      "id": "menu_right",
      "label": "t:labels.menu_right"
    },
    {
      "type": "header",
      "content": "t:general.localization"
    },
    {
      "type": "checkbox",
      "id": "show_localization",
      "label": "t:labels.show_localization",
      "default": true
    }
  ]
}
{% endschema %}
