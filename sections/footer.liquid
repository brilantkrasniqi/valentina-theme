<footer class="bg-v-cream border-t border-black/6 pt-20 pb-10 px-6 md:px-10">
  <div class="max-w-screen-xl mx-auto">

    <div class="grid grid-cols-2 md:grid-cols-4 gap-12 mb-20">

      {%- # Brand column -%}
      <div class="col-span-2 md:col-span-1">
        <p class="font-serif text-[1.6rem] font-light tracking-[.22em] uppercase mb-1">
          {{ shop.name }}
        </p>
        {%- if section.settings.tagline != blank -%}
          <p class="text-[7.5px] tracking-[.42em] uppercase text-v-rose font-light mb-7">
            {{ section.settings.tagline }}
          </p>
        {%- endif -%}
        {%- if section.settings.brand_blurb != blank -%}
          <p class="text-black/40 text-xs font-light leading-relaxed max-w-[200px]">
            {{ section.settings.brand_blurb }}
          </p>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'menu' -%}
          <div {{ block.shopify_attributes }}>
            <p class="text-[8px] tracking-[.38em] uppercase text-black/30 font-light mb-7">
              {{ block.settings.heading }}
            </p>
            <ul class="space-y-3.5">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a
                    href="{{ link.url }}"
                    class="ul-hover text-[13px] font-light text-black/65 hover:text-v-rose transition-colors"
                  >{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- # Bottom bar -%}
    <div class="border-t border-black/6 pt-8 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-black/30 text-[8.5px] tracking-[.28em] uppercase font-light">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.footer.rights_reserved' | t }}
      </p>

      <div class="flex flex-wrap items-center gap-6 sm:gap-8">
        {%- if section.settings.policy_menu != blank -%}
          {%- for link in section.settings.policy_menu.links -%}
            <a
              href="{{ link.url }}"
              class="text-black/30 text-[8.5px] tracking-[.28em] uppercase font-light hover:text-v-rose transition-colors"
            >{{ link.title }}</a>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="flex flex-wrap items-center gap-2">
          {%- for type in shop.enabled_payment_types -%}
            <span class="opacity-60">{{ type | payment_type_svg_tag: class: 'h-5' }}</span>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.tagline",
      "default": "Luxury Skincare"
    },
    {
      "type": "textarea",
      "id": "brand_blurb",
      "label": "t:labels.brand_blurb"
    },
    {
      "type": "link_list",
      "id": "policy_menu",
      "label": "t:labels.policy_menu"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "t:general.menu",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:labels.menu"
        }
      ]
    }
  ]
}
{% endschema %}
