<section
  class="relative bg-black text-white py-32 px-6 md:px-10 overflow-hidden"
  data-section-type="newsletter"
>
  <div class="absolute -top-32 -left-32 w-[420px] h-[420px] rounded-full bg-v-rose/20 blur-[120px] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -bottom-32 -right-32 w-[420px] h-[420px] rounded-full bg-v-rose/12 blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-2xl mx-auto text-center">
    {%- if section.settings.eyebrow != blank -%}
      <p class="reveal text-v-rose text-[9px] tracking-[.48em] uppercase font-light mb-9">
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}

    {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
      <h2
        class="reveal d1 font-serif text-white font-light leading-[1.1] mb-9"
        style="font-size: clamp(2.2rem, 5vw, 4rem);"
      >
        {%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- endif -%}
        {%- if section.settings.heading != blank and section.settings.heading_italic != blank -%}<br>{%- endif -%}
        {%- if section.settings.heading_italic != blank -%}<em class="italic text-v-rose">{{ section.settings.heading_italic }}</em>{%- endif -%}
      </h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <p class="reveal d2 text-white/45 text-sm font-light leading-[1.85] tracking-[.02em] max-w-md mx-auto mb-14">
        {{ section.settings.body }}
      </p>
    {%- endif -%}

    {%- form 'customer', class: 'reveal d3' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="hidden" name="contact[accepts_marketing]" value="true">

      {%- if form.posted_successfully? -%}
        <p class="text-v-rose text-sm font-light mb-6">{{ 'newsletter.success' | t }}</p>
      {%- endif -%}

      {%- if form.errors -%}
        <p class="text-red-400 text-sm font-light mb-6">{{ form.errors | default_errors }}</p>
      {%- endif -%}

      <div class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
        <label for="NewsletterEmail-{{ section.id }}" class="sr-only">{{ 'newsletter.email' | t }}</label>
        <input
          id="NewsletterEmail-{{ section.id }}"
          type="email"
          name="contact[email]"
          autocomplete="email"
          placeholder="{{ 'newsletter.email_placeholder' | t }}"
          required
          class="flex-1 bg-transparent border-b border-white/20 px-4 py-3 text-white placeholder-white/40 text-sm font-light tracking-[.04em] focus:outline-none focus:border-v-rose transition-colors duration-300"
        >
        <button
          type="submit"
          class="bg-v-rose text-white text-[10px] tracking-[.38em] uppercase font-light px-9 py-[14px] hover:bg-white hover:text-black transition-all duration-500"
        >
          {{ section.settings.button_label | default: 'newsletter.subscribe' | t }}
        </button>
      </div>
    {%- endform -%}

    {%- if section.settings.footnote != blank -%}
      <p class="reveal d4 text-white/30 text-[8.5px] tracking-[.32em] uppercase mt-10">
        {{ section.settings.footnote }}
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Stay Close"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Letters from"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "t:labels.heading_italic",
      "default": "the studio."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:labels.body",
      "default": "Slow rituals, new launches, founder reflections. No noise — just intention, delivered to your inbox."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "t:labels.footnote",
      "default": "By subscribing you agree to our Privacy Policy."
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter.name"
    }
  ]
}
{% endschema %}
