{%- assign crumb = 'sections.customers_activate_account.breadcrumb' | t -%}
{% render 'breadcrumbs', current_label: crumb %}

<section class="pb-24 px-6 md:px-10 bg-v-cream" data-section-type="customers-activate-account">
  <div class="max-w-md mx-auto pt-6">
    <h1 class="font-serif text-3xl font-light text-black mb-4 text-center">{{ 'customers.activate_account.title' | t }}</h1>
    <p class="text-sm text-black/45 font-light text-center mb-10">{{ 'customers.activate_account.subtext' | t }}</p>

    <div class="border border-black/10 bg-white/50 p-8 md:p-10">
      {% form 'activate_customer_password' %}
        {{ form.errors | default_errors }}
        <div class="space-y-5">
          <div>
            <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="CustomerPassword">{{ 'customers.activate_account.password' | t }}</label>
            <input
              type="password"
              name="customer[password]"
              id="CustomerPassword"
              autocomplete="new-password"
              class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
            >
          </div>
          <div>
            <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="CustomerPasswordConfirmation">{{ 'customers.activate_account.password_confirm' | t }}</label>
            <input
              type="password"
              name="customer[password_confirmation]"
              id="CustomerPasswordConfirmation"
              autocomplete="new-password"
              class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
            >
          </div>
          <button type="submit" class="w-full text-white text-[10px] tracking-[.38em] uppercase font-light bg-v-rose py-[14px] hover:bg-black transition-all duration-500 min-h-[48px]">
            {{ 'customers.activate_account.submit' | t }}
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.customers_activate_account.name",
  "tag": "section",
  "class": "section-customers-activate-account",
  "settings": [],
  "enabled_on": {
    "templates": ["customers/activate_account"]
  }
}
{% endschema %}
