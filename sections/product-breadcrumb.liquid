{%- liquid
  assign coll = product.collections.first
-%}
<div class="pt-24 pb-6 px-6 md:px-10 bg-v-cream" data-section-type="product-breadcrumb">
  <div class="max-w-screen-xl mx-auto">
    <nav class="flex items-center gap-2.5 flex-wrap" aria-label="{{ 'sections.product_breadcrumb.nav_aria' | t }}">
      <a href="{{ routes.root_url }}" class="text-[8.5px] tracking-[.32em] uppercase text-black/28 font-light hover:text-v-rose transition-colors">
        {{ 'sections.product_breadcrumb.home' | t }}
      </a>
      <span class="text-black/18 text-[9px]" aria-hidden="true">/</span>
      {%- if coll != blank -%}
        <a href="{{ coll.url }}" class="text-[8.5px] tracking-[.32em] uppercase text-black/28 font-light hover:text-v-rose transition-colors">
          {{ coll.title }}
        </a>
        <span class="text-black/18 text-[9px]" aria-hidden="true">/</span>
      {%- endif -%}
      <span class="text-[8.5px] tracking-[.32em] uppercase text-v-rose font-light">{{ product.title }}</span>
    </nav>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.product_breadcrumb.name",
  "tag": "section",
  "class": "section-product-breadcrumb",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
