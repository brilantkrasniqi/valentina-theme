{%- liquid
  assign sid = section.id | replace: '__', '-' | replace: '.', '-'
  assign carousel_id = 'related-splide-' | append: sid
-%}

<section class="py-32 px-6 md:px-10 bg-white border-t border-black/5" data-section-type="product-related">
  <div class="max-w-screen-xl mx-auto">

    <div class="text-center mb-16">
      {%- if section.settings.eyebrow != blank -%}
        <p class="reveal text-v-rose text-[9px] tracking-[.48em] uppercase font-light mb-5">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
        <h2
          class="reveal d1 font-serif text-black font-light"
          style="font-size: clamp(2rem, 4.5vw, 3.5rem);"
        >
          {%- if section.settings.heading != blank -%}{{ section.settings.heading }} {%- endif -%}
          {%- if section.settings.heading_italic != blank -%}<em class="italic text-v-rose">{{ section.settings.heading_italic }}</em>{%- endif -%}
        </h2>
      {%- endif -%}
    </div>

    {%- if section.settings.product_list != blank -%}
      <div id="{{ carousel_id }}" class="splide product-related-splide reveal" data-related-carousel="{{ sid }}">
        <div class="splide__track">
          <ul class="splide__list">
            {%- for p in section.settings.product_list -%}
              {%- if p.id == product.id -%}{% continue %}{%- endif -%}
              <li class="splide__slide">
                <a href="{{ p.url }}" class="p-card group block">
                  <div class="relative overflow-hidden bg-[#f0ebe9] aspect-[3/4]">
                    {%- if p.featured_media -%}
                      {{
                        p.featured_media.preview_image
                        | image_url: width: 800
                        | image_tag:
                          class: 'p-img absolute inset-0 w-full h-full object-cover transition-transform duration-[800ms] ease-[cubic-bezier(.25,.46,.45,.94)] group-hover:scale-[1.04]',
                          widths: '300, 500, 800',
                          sizes: '(min-width: 1024px) 30vw, 80vw',
                          loading: 'lazy',
                          alt: p.featured_media.alt | default: p.title
                      }}
                    {%- endif -%}
                    <div class="p-overlay absolute inset-0 bg-black/40 flex items-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-[450ms]">
                      <span class="w-full text-center text-white text-[9px] tracking-[.3em] uppercase border border-white/50 py-3 hover:bg-v-rose hover:border-v-rose transition-all duration-300 inline-block pointer-events-none">
                        {{ 'products.shop_now' | t }}
                      </span>
                    </div>
                  </div>
                  <div class="pt-5">
                    {%- if p.type != blank -%}
                      <p class="text-[8px] tracking-[.4em] uppercase text-black/28 font-light mb-1">{{ p.type }}</p>
                    {%- endif -%}
                    <h3 class="font-serif text-[1.15rem] font-light text-black mb-2">{{ p.title }}</h3>
                    {%- if p.description != blank -%}
                      <p class="text-black/40 text-[12px] font-light leading-relaxed mb-3 line-clamp-2">{{ p.description | strip_html | truncatewords: 18 }}</p>
                    {%- endif -%}
                    <p class="text-sm font-light text-black">{{ p.price_min | money }}</p>
                  </div>
                </a>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- else -%}
      <p class="text-center text-black/35 text-sm font-light">{{ 'sections.product_related.empty' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .product-related-splide .splide__arrows {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 2.5rem;
  }
  .product-related-splide .splide__arrow {
    position: static;
    transform: none;
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.12);
    width: 42px;
    height: 42px;
    border-radius: 0;
    opacity: 1;
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .product-related-splide .splide__arrow svg {
    fill: #1a1a1a;
    width: 12px;
    height: 12px;
  }
  .product-related-splide .splide__arrow:hover {
    background: #deaaa6;
    border-color: #deaaa6;
  }
  .product-related-splide .splide__arrow:hover svg {
    fill: #fff;
  }
  .product-related-splide .splide__arrow:disabled {
    opacity: 0.28;
    pointer-events: none;
  }
{% endstylesheet %}

<script>
  (function () {
    var el = document.querySelector('[data-related-carousel="{{ sid }}"]');
    if (!el || typeof Splide === 'undefined') return;
    if (el.dataset.splideInitialised === '1') return;
    el.dataset.splideInitialised = '1';
    new Splide(el, {
      perPage: 3,
      gap: '1.75rem',
      pagination: false,
      arrows: true,
      rewind: true,
      breakpoints: {
        1024: { perPage: 2 },
        640: { perPage: 1, padding: { right: '25%' } },
      },
    }).mount();
  })();
</script>

{% schema %}
{
  "name": "t:sections.product_related.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Complete Your Ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "You may also"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "t:labels.heading_italic",
      "default": "love."
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:sections.product_related.product_list",
      "limit": 6
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_related.name"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
