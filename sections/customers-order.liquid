{%- liquid
  assign parent_l = 'sections.customers_account.breadcrumb' | t
-%}
{% render 'breadcrumbs', current_label: order.name, parent_url: routes.account_url, parent_label: parent_l %}

<section class="pb-24 px-6 md:px-10 bg-v-cream" data-section-type="customers-order">
  <div class="max-w-4xl mx-auto pt-6">
    <div class="mb-10">
      <a href="{{ routes.account_url }}" class="text-[10px] tracking-[.32em] uppercase font-light text-black/50 hover:text-v-rose transition-colors">{{ 'customers.order.back' | t }}</a>
    </div>

    <header class="border border-black/10 bg-white/50 p-6 md:p-8 mb-8">
      <h1 class="font-serif text-2xl md:text-3xl font-light text-black mb-4">
        {{ 'customers.order.title' | t: name: order.name }}
      </h1>
      <p class="text-sm text-black/45 font-light">{{ order.created_at | date: format: 'date_at_time' }}</p>
      <div class="mt-6 flex flex-wrap gap-6 text-[10px] tracking-[.28em] uppercase font-light text-black/50">
        <span>{{ 'customers.order.payment' | t }}: {{ order.financial_status_label | default: order.financial_status }}</span>
        <span>{{ 'customers.order.fulfillment' | t }}: {{ order.fulfillment_status_label | default: order.fulfillment_status }}</span>
      </div>
      <p class="mt-6 font-serif text-xl font-light text-black">{{ order.total_price | money_with_currency }}</p>
    </header>

    <div class="border border-black/10 bg-white/40 overflow-x-auto">
      <table class="w-full text-left text-sm font-light" role="table">
        <thead class="text-[8px] tracking-[.32em] uppercase text-black/40 border-b border-black/8">
          <tr>
            <th class="px-4 py-3 font-light">{{ 'customers.order.product' | t }}</th>
            <th class="px-4 py-3 font-light">{{ 'customers.order.sku' | t }}</th>
            <th class="px-4 py-3 font-light text-right">{{ 'customers.order.price' | t }}</th>
            <th class="px-4 py-3 font-light text-right">{{ 'customers.order.quantity' | t }}</th>
            <th class="px-4 py-3 font-light text-right">{{ 'customers.order.total' | t }}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-black/8">
          {%- for line_item in order.line_items -%}
            <tr>
              <td class="px-4 py-4">
                {%- if line_item.url != blank -%}
                  <a href="{{ line_item.url }}" class="text-black hover:text-v-rose transition-colors">{{ line_item.title }}</a>
                {%- else -%}
                  <span class="text-black">{{ line_item.title }}</span>
                {%- endif -%}
                {%- unless line_item.selling_plan_allocation == nil -%}
                  <p class="text-[10px] text-black/35 mt-1">{{ line_item.selling_plan_allocation.selling_plan.name }}</p>
                {%- endunless -%}
              </td>
              <td class="px-4 py-4 text-black/45">{{ line_item.sku }}</td>
              <td class="px-4 py-4 text-right">{{ line_item.price | money }}</td>
              <td class="px-4 py-4 text-right">{{ line_item.quantity }}</td>
              <td class="px-4 py-4 text-right">{{ line_item.final_line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    <div class="mt-8 border border-black/10 bg-white/40 p-6 text-sm font-light text-black/60 space-y-2">
      <div class="flex justify-between"><span>{{ 'customers.order.subtotal' | t }}</span><span>{{ order.subtotal_price | money }}</span></div>
      {%- for line in order.shipping_lines -%}
        <div class="flex justify-between">
          <span>{{ line.title }}</span>
          <span>{{ line.price | money }}</span>
        </div>
      {%- endfor -%}
      {%- for discount in order.discount_applications -%}
        <div class="flex justify-between text-v-rose">
          <span>{{ discount.title }}</span>
          <span>-{{ discount.total_allocated_amount | money }}</span>
        </div>
      {%- endfor -%}
      <div class="flex justify-between pt-2 border-t border-black/8 text-black font-normal">
        <span>{{ 'customers.order.total' | t }}</span>
        <span>{{ order.total_price | money_with_currency }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.customers_order.name",
  "tag": "section",
  "class": "section-customers-order",
  "settings": [],
  "enabled_on": {
    "templates": ["customers/order"]
  }
}
{% endschema %}
