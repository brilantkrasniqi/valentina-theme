<div class="pt-24 pb-6 px-6 md:px-10 bg-v-cream" data-section-type="cart-breadcrumb">
  <div class="max-w-screen-xl mx-auto">
    <nav class="flex items-center gap-2.5 flex-wrap" aria-label="{{ 'sections.cart_breadcrumb.nav_aria' | t }}">
      <a href="{{ routes.root_url }}" class="text-[8.5px] tracking-[.32em] uppercase text-black/28 font-light hover:text-v-rose transition-colors">
        {{ 'sections.cart_breadcrumb.home' | t }}
      </a>
      <span class="text-black/18 text-[9px]" aria-hidden="true">/</span>
      <span class="text-[8.5px] tracking-[.32em] uppercase text-v-rose font-light">{{ 'cart.title' | t }}</span>
    </nav>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.cart_breadcrumb.name",
  "tag": "section",
  "class": "section-cart-breadcrumb",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
