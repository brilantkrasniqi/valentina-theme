{% liquid
  assign crumb = page.title | truncate: 48
%}
{% render 'breadcrumbs', current_label: crumb %}

<section class="pb-24 md:pb-32 px-6 md:px-10 bg-v-cream" data-section-type="main-page">
  <div class="max-w-screen-xl mx-auto pt-10 md:pt-6">
    {%- if section.settings.eyebrow != blank -%}
      <p class="text-v-rose text-[9px] tracking-[.48em] uppercase font-light mb-5">
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}

    <h1 class="font-serif text-black font-light mb-10 md:mb-12" style="font-size: clamp(2rem, 4.5vw, 3rem);">
      {{ page.title }}
    </h1>

    <div
      class="main-page-content rte text-black/70 text-sm md:text-[15px] font-light leading-[1.85] tracking-[.02em] max-w-3xl
        [&_h1]:font-serif [&_h1]:text-black [&_h1]:font-light [&_h1]:text-2xl [&_h1]:mb-4 [&_h1]:mt-10
        [&_h2]:font-serif [&_h2]:text-black [&_h2]:font-light [&_h2]:text-xl [&_h2]:mb-3 [&_h2]:mt-8
        [&_h3]:font-serif [&_h3]:text-black [&_h3]:font-light [&_h3]:text-lg [&_h3]:mb-2 [&_h3]:mt-6
        [&_p]:mb-4 [&_a]:text-v-rose [&_a]:underline-offset-4 hover:[&_a]:text-black
        [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:mb-4 [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:mb-4
        [&_blockquote]:border-l-2 [&_blockquote]:border-v-rose/50 [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-black/55"
    >
      {{ page.content }}
    </div>
  </div>
</section>

{% stylesheet %}
  .main-page-content img {
    max-width: 100%;
    height: auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main_page.name",
  "tag": "section",
  "class": "section-main-page",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Valentina"
    }
  ]
}
{% endschema %}
