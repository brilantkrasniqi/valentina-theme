{%- assign crumb = 'sections.customers_recover_password.breadcrumb' | t -%}
{% render 'breadcrumbs', current_label: crumb %}

<section class="pb-24 px-6 md:px-10 bg-v-cream" data-section-type="customers-recover-password">
  <div class="max-w-md mx-auto pt-6">
    <h1 class="font-serif text-3xl font-light text-black mb-4 text-center">{{ 'customers.recover_password.title' | t }}</h1>
    <p class="text-sm text-black/45 font-light text-center mb-10">{{ 'customers.recover_password.subtext' | t }}</p>

    <div class="border border-black/10 bg-white/50 p-8 md:p-10">
      {% form 'recover_customer_password' %}
        {{ form.errors | default_errors }}

        {%- if form.posted_successfully? -%}
          <p class="text-sm text-v-rose font-light mb-6">{{ 'customers.recover_password.success' | t }}</p>
        {%- endif -%}

        <div class="space-y-5">
          <div>
            <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="RecoverEmail">{{ 'customers.recover_password.email' | t }}</label>
            <input
              type="email"
              name="email"
              id="RecoverEmail"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
            >
          </div>
          <button type="submit" class="w-full text-white text-[10px] tracking-[.38em] uppercase font-light bg-v-rose py-[14px] hover:bg-black transition-all duration-500 min-h-[48px]">
            {{ 'customers.recover_password.submit' | t }}
          </button>
        </div>
      {% endform %}

      <p class="mt-8 text-center text-[10px] tracking-[.28em] uppercase font-light">
        <a href="{{ routes.account_login_url }}" class="text-black/50 hover:text-v-rose transition-colors">{{ 'customers.recover_password.cancel' | t }}</a>
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.customers_recover_password.name",
  "tag": "section",
  "class": "section-customers-recover-password",
  "settings": []
}
{% endschema %}
