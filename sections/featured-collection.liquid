<section class="py-32 px-6 md:px-10 bg-v-cream" data-section-type="featured-collection">
  <div class="max-w-screen-xl mx-auto">

    <div class="text-center mb-20">
      {%- if section.settings.eyebrow != blank -%}
        <p class="reveal text-v-rose text-[9px] tracking-[.48em] uppercase font-light mb-5">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
        <h2
          class="reveal d1 font-serif text-black font-light"
          style="font-size: clamp(2.2rem, 5vw, 4rem);"
        >
          {%- if section.settings.heading != blank -%}{{ section.settings.heading }} {%- endif -%}
          {%- if section.settings.heading_italic != blank -%}<em class="italic text-v-rose">{{ section.settings.heading_italic }}</em>{%- endif -%}
        </h2>
      {%- endif -%}
    </div>

    {%- liquid
      assign collection = section.settings.collection
      assign products = collection.products | default: empty
      assign limit = section.settings.products_to_show | default: 4
    -%}

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-5 md:gap-8 items-start">
      {%- for product in products limit: limit -%}
        {%- liquid
          assign reveal_class = 'reveal'
          assign forloop_index = forloop.index
          if forloop.index == 1
            assign reveal_class = 'reveal d1'
          elsif forloop.index == 2
            assign reveal_class = 'reveal d2 lg:mt-16'
          elsif forloop.index == 3
            assign reveal_class = 'reveal d3'
          elsif forloop.index == 4
            assign reveal_class = 'reveal d4 lg:mt-16'
          endif

          assign badge_label = ''
          assign badge_class = ''
          if product.tags contains 'bestseller' or product.tags contains 'Bestseller'
            assign badge_label = 'products.badge.bestseller' | t
            assign badge_class = 'bg-v-rose text-white'
          elsif product.tags contains 'new' or product.tags contains 'New'
            assign badge_label = 'products.badge.new' | t
            assign badge_class = 'bg-black text-white'
          elsif product.compare_at_price > product.price
            assign badge_label = 'products.badge.sale' | t
            assign badge_class = 'bg-black text-white'
          endif

          assign vendor_or_type = product.type | default: product.vendor
        -%}

        <a href="{{ product.url }}" class="p-card cursor-pointer block {{ reveal_class }}">
          <div class="relative overflow-hidden bg-[#f0ebe9] aspect-[3/4] img-zoom-parent">
            {%- if product.featured_image != blank -%}
              {{
                product.featured_image
                | image_url: width: 800
                | image_tag:
                  class: 'img-zoom absolute inset-0 w-full h-full object-cover',
                  widths: '300, 450, 600, 800',
                  sizes: '(min-width: 1024px) 25vw, 50vw',
                  loading: 'lazy',
                  alt: product.featured_image.alt | default: product.title
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'absolute inset-0 w-full h-full object-cover bg-v-rose-light' }}
            {%- endif -%}
            <div class="absolute inset-0 bg-black/40 opacity-0 hover:opacity-100 transition-opacity duration-500 flex items-end p-5 md:p-6">
              <span class="w-full text-center text-white text-[9px] tracking-[.3em] uppercase border border-white/50 py-3 hover:bg-v-rose hover:border-v-rose transition-all duration-300">
                {{ 'products.shop_now' | t }}
              </span>
            </div>
            {%- if badge_label != '' -%}
              <span class="absolute top-4 left-4 {{ badge_class }} text-[7.5px] tracking-[.28em] uppercase px-3 py-[4px]">
                {{ badge_label }}
              </span>
            {%- endif -%}
          </div>

          <div class="pt-5">
            {%- if vendor_or_type != blank -%}
              <p class="text-[8px] tracking-[.4em] uppercase text-black/30 font-light mb-1">
                {{ vendor_or_type }}
              </p>
            {%- endif -%}
            <h3 class="font-serif text-[1.15rem] font-light text-black mb-2">{{ product.title }}</h3>
            {%- if product.metafields.descriptors.subtitle != blank -%}
              <p class="text-black/40 text-[12px] font-light leading-relaxed mb-3 hidden sm:block">
                {{ product.metafields.descriptors.subtitle }}
              </p>
            {%- endif -%}
            <p class="text-sm font-light text-black">
              {%- if product.compare_at_price > product.price -%}
                <span class="line-through text-black/30 mr-2">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
              {{ product.price | money }}
            </p>
          </div>
        </a>
      {%- else -%}
        {%- # No collection / empty: render placeholder cards so the section is visible in the editor -%}
        {%- for i in (1..4) -%}
          <div class="p-card block">
            <div class="relative overflow-hidden bg-[#f0ebe9] aspect-[3/4]">
              {{ 'product-' | append: i | placeholder_svg_tag: 'absolute inset-0 w-full h-full object-cover' }}
            </div>
            <div class="pt-5">
              <p class="text-[8px] tracking-[.4em] uppercase text-black/30 font-light mb-1">{{ 'products.placeholder.category' | t }}</p>
              <h3 class="font-serif text-[1.15rem] font-light text-black mb-2">{{ 'products.placeholder.title' | t }}</h3>
              <p class="text-sm font-light text-black">€00</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div class="text-center mt-20 reveal">
        <a
          href="{{ section.settings.cta_url | default: collection.url | default: routes.all_products_collection_url }}"
          class="inline-flex items-center gap-4 text-black text-[10px] tracking-[.38em] uppercase font-light border border-black/20 px-12 py-[14px] hover:bg-black hover:text-white transition-all duration-500"
        >{{ section.settings.cta_label }}</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Four acts of"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "t:labels.heading_italic",
      "default": "devotion."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:labels.products_to_show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:labels.cta_label",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:labels.cta_url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.name"
    }
  ]
}
{% endschema %}
