<section class="py-32 px-6 md:px-10 bg-v-cream" data-section-type="ritual-steps">
  <div class="max-w-screen-xl mx-auto">

    <div class="text-center mb-20">
      {%- if section.settings.eyebrow != blank -%}
        <p class="reveal text-v-rose text-[9px] tracking-[.48em] uppercase font-light mb-5">
          {{ section.settings.eyebrow }}
        </p>
      {%- endif -%}
      {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
        <h2
          class="reveal d1 font-serif text-black font-light"
          style="font-size: clamp(2.2rem, 5vw, 4rem);"
        >
          {%- if section.settings.heading != blank -%}{{ section.settings.heading }} {%- endif -%}
          {%- if section.settings.heading_italic != blank -%}<em class="italic text-v-rose">{{ section.settings.heading_italic }}</em>{%- endif -%}
        </h2>
      {%- endif -%}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-l border-t border-black/8">
      {%- for block in section.blocks -%}
        {%- liquid
          assign delay = ''
          if forloop.index == 1
            assign delay = 'd1'
          elsif forloop.index == 2
            assign delay = 'd2'
          elsif forloop.index == 3
            assign delay = 'd3'
          elsif forloop.index == 4
            assign delay = 'd4'
          endif
        -%}
        <div
          class="reveal {{ delay }} border-r border-b border-black/8 px-8 py-14 text-center hover:bg-white/40 transition-colors duration-500"
          {{ block.shopify_attributes }}
        >
          <div class="font-serif text-v-rose text-[3.5rem] font-light leading-none mb-7">
            {{ block.settings.number }}
          </div>
          <h3 class="font-serif text-black text-xl font-light tracking-wide mb-4">
            {{ block.settings.title }}
          </h3>
          {%- if block.settings.body != blank -%}
            <p class="text-black/45 text-[12.5px] font-light leading-[1.85] tracking-[.02em]">
              {{ block.settings.body }}
            </p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.ritual_steps.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "The Ritual"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Four moments to"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "t:labels.heading_italic",
      "default": "yourself."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.ritual_steps.step",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "t:labels.number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Cleanse"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "t:labels.body",
          "default": "Begin in stillness. Wash away the day with our cleansing balm — a slow ceremony of melting, breathing, returning."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.ritual_steps.name",
      "blocks": [
        { "type": "step", "settings": { "number": "01", "title": "Cleanse" } },
        { "type": "step", "settings": { "number": "02", "title": "Tone" } },
        { "type": "step", "settings": { "number": "03", "title": "Treat" } },
        { "type": "step", "settings": { "number": "04", "title": "Nourish" } }
      ]
    }
  ]
}
{% endschema %}
