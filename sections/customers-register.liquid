{%- assign crumb = 'sections.customers_register.breadcrumb' | t -%}
{% render 'breadcrumbs', current_label: crumb %}

<section class="pb-24 px-6 md:px-10 bg-v-cream" data-section-type="customers-register">
  <div class="max-w-md mx-auto pt-6">
    <h1 class="font-serif text-3xl font-light text-black mb-8 text-center">{{ 'customers.register.title' | t }}</h1>

    <div class="border border-black/10 bg-white/50 p-8 md:p-10">
      {% form 'create_customer' %}
        {{ form.errors | default_errors }}

        <div class="space-y-5">
          <div>
            <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="RegisterFirstName">{{ 'customers.register.first_name' | t }}</label>
            <input
              type="text"
              name="customer[first_name]"
              id="RegisterFirstName"
              value="{{ form.first_name }}"
              autocomplete="given-name"
              class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
            >
          </div>
          <div>
            <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="RegisterLastName">{{ 'customers.register.last_name' | t }}</label>
            <input
              type="text"
              name="customer[last_name]"
              id="RegisterLastName"
              value="{{ form.last_name }}"
              autocomplete="family-name"
              class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
            >
          </div>
          <div>
            <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="RegisterEmail">{{ 'customers.register.email' | t }}</label>
            <input
              type="email"
              name="customer[email]"
              id="RegisterEmail"
              value="{{ form.email }}"
              autocomplete="email"
              class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
            >
          </div>
          <div>
            <label class="block text-[8px] tracking-[.32em] uppercase text-black/40 font-light mb-2" for="RegisterPassword">{{ 'customers.register.password' | t }}</label>
            <input
              type="password"
              name="customer[password]"
              id="RegisterPassword"
              autocomplete="new-password"
              class="w-full border border-black/15 px-4 py-3 text-sm font-light bg-white focus:outline-none focus:border-v-rose"
            >
          </div>

          <button type="submit" class="w-full text-white text-[10px] tracking-[.38em] uppercase font-light bg-v-rose py-[14px] hover:bg-black transition-all duration-500 min-h-[48px]">
            {{ 'customers.register.submit' | t }}
          </button>
        </div>
      {% endform %}

      <p class="mt-8 text-center text-[10px] tracking-[.28em] uppercase font-light">
        <a href="{{ routes.account_login_url }}" class="text-black/50 hover:text-v-rose transition-colors">{{ 'customers.register.sign_in' | t }}</a>
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.customers_register.name",
  "tag": "section",
  "class": "section-customers-register",
  "settings": [],
  "enabled_on": {
    "templates": ["customers/register"]
  }
}
{% endschema %}
