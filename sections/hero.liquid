<section
  data-section-type="hero"
  class="relative h-screen min-h-[700px] overflow-hidden"
>
  {%- if section.settings.image != blank -%}
    {{
      section.settings.image
      | image_url: width: 2400
      | image_tag:
        class: 'absolute inset-0 w-full h-full object-cover object-top',
        widths: '600, 900, 1200, 1600, 2000, 2400',
        sizes: '100vw',
        loading: 'eager',
        fetchpriority: 'high',
        alt: section.settings.image.alt | default: section.settings.heading
    }}
  {%- else -%}
    <div class="absolute inset-0 bg-gradient-to-br from-v-rose to-v-rose-dark"></div>
  {%- endif -%}

  <div class="hero-grad absolute inset-0"></div>

  <div class="relative z-10 h-full flex flex-col items-center justify-center text-center px-6">
    {%- if section.settings.eyebrow != blank -%}
      <p class="hero-item h-d0 text-v-rose text-[9px] tracking-[.55em] uppercase font-light mb-10">
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}

    {%- if section.settings.heading != blank or section.settings.heading_italic != blank -%}
      <h1
        class="hero-item h-d1 font-serif text-white font-light leading-none mb-6"
        style="font-size: clamp(3.8rem, 11.5vw, 9.5rem); text-shadow: 0 0 140px rgba(222,170,166,.22);"
      >
        {%- if section.settings.heading != blank -%}{{ section.settings.heading }}{%- endif -%}
        {%- if section.settings.heading != blank and section.settings.heading_italic != blank -%}<br>{%- endif -%}
        {%- if section.settings.heading_italic != blank -%}<em class="italic">{{ section.settings.heading_italic }}</em>{%- endif -%}
      </h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-item h-d2 text-white/60 text-[11px] md:text-xs tracking-[.22em] uppercase font-light max-w-[22ch] mx-auto mb-14">
        {{ section.settings.subheading }}
      </p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_url | default: '#' }}"
        class="hero-item h-d3 inline-flex items-center gap-5 text-white text-[10px] tracking-[.38em] uppercase font-light border border-white/30 px-10 py-[14px] hover:bg-v-rose hover:border-v-rose transition-all duration-500"
      >{{ section.settings.cta_label }}</a>
    {%- endif -%}
  </div>

  {%- if section.settings.show_scroll_cue -%}
    <div class="absolute bottom-9 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 z-10 pointer-events-none">
      <span class="text-white/35 text-[8px] tracking-[.38em] uppercase">{{ 'sections.hero.scroll' | t }}</span>
      <div class="float w-px h-10 bg-gradient-to-b from-white/35 to-transparent"></div>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "t:sections.hero.name",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.background_image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Since 2024 · Paris Inspired"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Feel"
    },
    {
      "type": "text",
      "id": "heading_italic",
      "label": "t:labels.heading_italic",
      "default": "Luminous."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Skincare born from the language of desire"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:labels.cta_label",
      "default": "Discover the Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:labels.cta_url"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_cue",
      "label": "t:labels.show_scroll_cue",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero.name"
    }
  ]
}
{% endschema %}
