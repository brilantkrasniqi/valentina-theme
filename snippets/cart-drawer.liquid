{% doc %}
  Slide-in cart drawer rendered as a <dialog> element.

  Uses Shopify's AJAX Cart API:
    - GET  /cart.js                 → fetch cart state
    - POST /cart/add.js             → add to cart (intercepts product forms)
    - POST /cart/change.js          → update / remove a line by index

  Locale-aware URLs are built from `window.Shopify.routes.root`.

  @example
  {% render 'cart-drawer' %}
{% enddoc %}

<dialog
  id="CartDrawer"
  data-cart-drawer
  class="cart-drawer text-black"
  aria-label="{{ 'cart.title' | t }}"
>
  <div class="flex flex-col h-full">
    <header class="flex items-center justify-between px-7 py-5 border-b border-black/8">
      <p class="font-serif text-xl font-light tracking-wide">
        {{ 'cart.title' | t }} <span data-cart-drawer-count class="text-v-rose">({{ cart.item_count }})</span>
      </p>
      <button
        type="button"
        data-cart-drawer-close
        aria-label="{{ 'general.accessibility.close' | t }}"
        class="text-black/60 hover:text-v-rose transition-colors duration-300"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.4" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </header>

    <div data-cart-drawer-body class="flex-1 overflow-y-auto">
      {%- if cart.item_count == 0 -%}
        <div data-cart-drawer-empty class="flex flex-col items-center justify-center text-center py-20 px-8 h-full">
          <p class="font-serif text-xl font-light italic mb-4 text-black/70">
            {{ 'cart.empty_title' | t }}
          </p>
          <p class="text-black/40 text-[12px] tracking-[.05em] mb-9 max-w-[24ch]">
            {{ 'cart.empty_body' | t }}
          </p>
          <a
            href="{{ routes.all_products_collection_url }}"
            data-cart-drawer-close
            class="inline-block text-black text-[10px] tracking-[.38em] uppercase font-light border border-black/20 px-9 py-[14px] hover:border-v-rose hover:text-v-rose transition-all duration-300"
          >{{ 'cart.start_shopping' | t }}</a>
        </div>
      {%- else -%}
        <ul data-cart-drawer-lines class="divide-y divide-black/8">
          {%- for item in cart.items -%}
            <li class="flex gap-4 p-5" data-cart-line="{{ forloop.index }}">
              <a href="{{ item.url }}" class="shrink-0 w-20 h-24 bg-[#f0ebe9] overflow-hidden">
                {%- if item.image != blank -%}
                  {{ item.image | image_url: width: 200 | image_tag: class: 'w-full h-full object-cover', loading: 'lazy', alt: item.title }}
                {%- endif -%}
              </a>
              <div class="flex-1 min-w-0 flex flex-col">
                <div class="flex items-start justify-between gap-2">
                  <a href="{{ item.url }}" class="font-serif text-[15px] font-light leading-snug hover:text-v-rose transition-colors">
                    {{ item.product.title }}
                  </a>
                  <button
                    type="button"
                    data-cart-remove
                    data-line="{{ forloop.index }}"
                    aria-label="{{ 'cart.remove' | t }}"
                    class="text-black/40 hover:text-v-rose transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </button>
                </div>
                {%- unless item.variant.title contains 'Default' -%}
                  <p class="text-black/45 text-[11px] tracking-[.04em] mt-1">{{ item.variant.title }}</p>
                {%- endunless -%}

                <div class="mt-auto flex items-center justify-between pt-3">
                  <div class="inline-flex items-center border border-black/15">
                    <button type="button" data-cart-qty-change="dec" data-line="{{ forloop.index }}" class="w-7 h-7 flex items-center justify-center hover:bg-black/5" aria-label="{{ 'cart.decrease' | t }}">−</button>
                    <span data-cart-qty="{{ forloop.index }}" class="w-7 text-center text-sm">{{ item.quantity }}</span>
                    <button type="button" data-cart-qty-change="inc" data-line="{{ forloop.index }}" class="w-7 h-7 flex items-center justify-center hover:bg-black/5" aria-label="{{ 'cart.increase' | t }}">+</button>
                  </div>
                  <p class="text-sm font-light">{{ item.final_line_price | money }}</p>
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <footer
      data-cart-drawer-footer
      class="border-t border-black/8 p-7 space-y-5 {% if cart.item_count == 0 %}hidden{% endif %}"
    >
      <div class="flex items-center justify-between">
        <p class="text-[10px] tracking-[.36em] uppercase font-light text-black/45">
          {{ 'cart.subtotal' | t }}
        </p>
        <p data-cart-drawer-subtotal class="font-serif text-xl font-light">
          {{ cart.total_price | money }}
        </p>
      </div>

      <p class="text-[10px] text-black/40 font-light tracking-[.04em]">
        {{ 'cart.shipping_note' | t }}
      </p>

      <a
        href="{{ routes.cart_url }}"
        class="block text-center w-full text-black text-[10px] tracking-[.38em] uppercase font-light border border-black/20 py-[14px] hover:border-v-rose hover:text-v-rose transition-all duration-300"
      >{{ 'cart.view_cart' | t }}</a>

      <a
        href="{{ routes.cart_url }}/checkout"
        class="block text-center w-full text-white text-[10px] tracking-[.38em] uppercase font-light bg-v-rose py-[14px] hover:bg-black transition-all duration-500"
      >{{ 'cart.checkout' | t }}</a>
    </footer>
  </div>
</dialog>

{%- # Translation strings shared with the JS renderer -%}
<script type="application/json" data-cart-drawer-strings>
  {
    "remove":          {{ 'cart.remove' | t | json }},
    "decrease":        {{ 'cart.decrease' | t | json }},
    "increase":        {{ 'cart.increase' | t | json }},
    "empty_title":     {{ 'cart.empty_title' | t | json }},
    "empty_body":      {{ 'cart.empty_body' | t | json }},
    "start_shopping":  {{ 'cart.start_shopping' | t | json }},
    "all_products_url": {{ routes.all_products_collection_url | json }}
  }
</script>

{% javascript %}
  (function () {
    var dialog = document.getElementById('CartDrawer');
    if (!dialog) return;

    var rootUrl = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
    if (rootUrl.charAt(rootUrl.length - 1) !== '/') rootUrl += '/';

    var stringsEl = document.querySelector('[data-cart-drawer-strings]');
    var strings = stringsEl ? JSON.parse(stringsEl.textContent) : {};

    var body        = dialog.querySelector('[data-cart-drawer-body]');
    var footer      = dialog.querySelector('[data-cart-drawer-footer]');
    var countEls    = document.querySelectorAll('[data-cart-count]');
    var drawerCount = dialog.querySelector('[data-cart-drawer-count]');
    var subtotalEl  = dialog.querySelector('[data-cart-drawer-subtotal]');

    function open() {
      if (typeof dialog.showModal === 'function' && !dialog.open) {
        dialog.showModal();
      } else if (!dialog.hasAttribute('open')) {
        dialog.setAttribute('open', '');
      }
      document.documentElement.style.overflow = 'hidden';
    }

    function close() {
      if (typeof dialog.close === 'function') {
        dialog.close();
      } else {
        dialog.removeAttribute('open');
      }
      document.documentElement.style.overflow = '';
    }

    function escapeHtml(str) {
      return String(str || '').replace(/[&<>"']/g, function (c) {
        return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c];
      });
    }

    function formatMoney(cents) {
      var currency = (window.Shopify && Shopify.currency && Shopify.currency.active) || 'USD';
      try {
        return (cents / 100).toLocaleString(document.documentElement.lang || 'en', {
          style: 'currency',
          currency: currency,
        });
      } catch (e) {
        return currency + ' ' + (cents / 100).toFixed(2);
      }
    }

    function renderEmpty() {
      return (
        '<div data-cart-drawer-empty class="flex flex-col items-center justify-center text-center py-20 px-8 h-full">' +
          '<p class="font-serif text-xl font-light italic mb-4 text-black/70">' + escapeHtml(strings.empty_title) + '</p>' +
          '<p class="text-black/40 text-[12px] tracking-[.05em] mb-9 max-w-[24ch]">' + escapeHtml(strings.empty_body) + '</p>' +
          '<a href="' + escapeHtml(strings.all_products_url) + '" data-cart-drawer-close class="inline-block text-black text-[10px] tracking-[.38em] uppercase font-light border border-black/20 px-9 py-[14px] hover:border-v-rose hover:text-v-rose transition-all duration-300">' +
            escapeHtml(strings.start_shopping) +
          '</a>' +
        '</div>'
      );
    }

    function renderLine(item, index) {
      var imageHtml = item.image
        ? '<img src="' + escapeHtml(item.image) + '" alt="' + escapeHtml(item.product_title) + '" class="w-full h-full object-cover" loading="lazy">'
        : '';
      var variantHtml = (item.variant_title && item.variant_title.toLowerCase().indexOf('default') === -1)
        ? '<p class="text-black/45 text-[11px] tracking-[.04em] mt-1">' + escapeHtml(item.variant_title) + '</p>'
        : '';

      return (
        '<li class="flex gap-4 p-5" data-cart-line="' + index + '">' +
          '<a href="' + escapeHtml(item.url) + '" class="shrink-0 w-20 h-24 bg-[#f0ebe9] overflow-hidden">' + imageHtml + '</a>' +
          '<div class="flex-1 min-w-0 flex flex-col">' +
            '<div class="flex items-start justify-between gap-2">' +
              '<a href="' + escapeHtml(item.url) + '" class="font-serif text-[15px] font-light leading-snug hover:text-v-rose transition-colors">' +
                escapeHtml(item.product_title) +
              '</a>' +
              '<button type="button" data-cart-remove data-line="' + index + '" aria-label="' + escapeHtml(strings.remove) + '" class="text-black/40 hover:text-v-rose transition-colors">' +
                '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3" d="M6 18L18 6M6 6l12 12"/></svg>' +
              '</button>' +
            '</div>' +
            variantHtml +
            '<div class="mt-auto flex items-center justify-between pt-3">' +
              '<div class="inline-flex items-center border border-black/15">' +
                '<button type="button" data-cart-qty-change="dec" data-line="' + index + '" class="w-7 h-7 flex items-center justify-center hover:bg-black/5" aria-label="' + escapeHtml(strings.decrease) + '">−</button>' +
                '<span data-cart-qty="' + index + '" class="w-7 text-center text-sm">' + item.quantity + '</span>' +
                '<button type="button" data-cart-qty-change="inc" data-line="' + index + '" class="w-7 h-7 flex items-center justify-center hover:bg-black/5" aria-label="' + escapeHtml(strings.increase) + '">+</button>' +
              '</div>' +
              '<p class="text-sm font-light">' + formatMoney(item.final_line_price) + '</p>' +
            '</div>' +
          '</div>' +
        '</li>'
      );
    }

    function render(cart) {
      countEls.forEach(function (el) {
        el.textContent = cart.item_count;
        el.classList.toggle('hidden', cart.item_count === 0);
      });
      if (drawerCount) drawerCount.textContent = '(' + cart.item_count + ')';
      if (subtotalEl)  subtotalEl.textContent = formatMoney(cart.total_price);
      if (footer)      footer.classList.toggle('hidden', cart.item_count === 0);

      if (!body) return;
      if (cart.item_count === 0) {
        body.innerHTML = renderEmpty();
        return;
      }
      var html = '<ul data-cart-drawer-lines class="divide-y divide-black/8">';
      cart.items.forEach(function (item, i) { html += renderLine(item, i + 1); });
      html += '</ul>';
      body.innerHTML = html;
    }

    function refresh() {
      return fetch(rootUrl + 'cart.js', { headers: { Accept: 'application/json' } })
        .then(function (res) { return res.json(); })
        .then(function (cart) { render(cart); return cart; });
    }

    // ── Open / close ────────────────────────────────────────────────
    document.addEventListener('click', function (e) {
      var openBtn  = e.target.closest('[data-cart-drawer-open]');
      var closeBtn = e.target.closest('[data-cart-drawer-close]');

      if (openBtn) {
        e.preventDefault();
        open();
        refresh();
        return;
      }

      if (closeBtn) {
        e.preventDefault();
        close();
        return;
      }

      if (e.target === dialog) {
        var rect = dialog.getBoundingClientRect();
        var inside =
          e.clientX >= rect.left && e.clientX <= rect.right &&
          e.clientY >= rect.top  && e.clientY <= rect.bottom;
        if (!inside) close();
      }
    });

    dialog.addEventListener('cancel', function (e) {
      e.preventDefault();
      close();
    });

    // ── Quantity / remove ───────────────────────────────────────────
    body.addEventListener('click', function (e) {
      var qtyBtn = e.target.closest('[data-cart-qty-change]');
      var rmBtn  = e.target.closest('[data-cart-remove]');

      if (qtyBtn) {
        var line = parseInt(qtyBtn.getAttribute('data-line'), 10);
        var dir  = qtyBtn.getAttribute('data-cart-qty-change');
        var qtyEl = body.querySelector('[data-cart-qty="' + line + '"]');
        if (!qtyEl) return;
        var current = parseInt(qtyEl.textContent.trim(), 10) || 0;
        var next = dir === 'inc' ? current + 1 : Math.max(0, current - 1);
        changeLine(line, next);
      }

      if (rmBtn) {
        changeLine(parseInt(rmBtn.getAttribute('data-line'), 10), 0);
      }
    });

    function changeLine(line, quantity) {
      return fetch(rootUrl + 'cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({ line: line, quantity: quantity }),
      })
        .then(function (res) { return res.json(); })
        .then(function (cart) { render(cart); return cart; });
    }

    // ── Intercept product forms ─────────────────────────────────────
    document.addEventListener('submit', function (e) {
      var form = e.target;
      if (!(form instanceof HTMLFormElement)) return;
      if (!form.action || form.action.indexOf('/cart/add') === -1) return;

      e.preventDefault();
      var btn = form.querySelector('button[type="submit"], input[type="submit"]');
      if (btn) btn.setAttribute('disabled', 'disabled');

      fetch(rootUrl + 'cart/add.js', {
        method: 'POST',
        headers: { Accept: 'application/javascript' },
        body: new FormData(form),
      })
        .then(function (res) {
          if (!res.ok) return res.json().then(function (err) { throw err; });
          return res.json();
        })
        .then(function () { return refresh(); })
        .then(function () { open(); })
        .catch(function (err) {
          if (err && err.description) alert(err.description);
        })
        .finally(function () {
          if (btn) btn.removeAttribute('disabled');
        });
    });

    // Initial sync (handles cross-tab cart changes)
    refresh();
  })();
{% endjavascript %}
